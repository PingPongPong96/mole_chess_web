{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": [
    "playwright.config.ts",
    "tests-api/**/*",
    "tests-e2e/**/*",
    "tests-support/**/*"
  ]
}
